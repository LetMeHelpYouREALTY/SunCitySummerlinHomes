# Copy to .env.local for local development. Set real values in Vercel → Environment Variables.
#
# Local Node: use 22.x (see .nvmrc and package.json "engines"). With .npmrc engine-strict=true,
# npm install fails on unsupported Node versions — intentional drift prevention.

# Google Search Console — HTML tag verification (content value only, not the full tag).
# https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Analytics 4
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Maps (map page)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# RealScout — public portal for “search listings” CTAs (not /onboarding). Widget agent id.
NEXT_PUBLIC_REALSCOUT_URL=https://drjanduffy.realscout.com/
NEXT_PUBLIC_REALSCOUT_AGENT_ID=QWdlbnQtMjI1MDUw
