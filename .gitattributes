# LF for common text sources (reduces Windows CRLF warnings on git add).
# Recommended for this clone: git config core.autocrlf false
*.ts       text eol=lf
*.tsx      text eol=lf
*.js       text eol=lf
*.jsx      text eol=lf
*.mjs      text eol=lf
*.cjs      text eol=lf
*.json     text eol=lf
*.css      text eol=lf
*.md       text eol=lf
*.yml      text eol=lf
*.yaml     text eol=lf
*.html     text eol=lf
*.htm      text eol=lf
*.txt      text eol=lf
*.svg      text eol=lf
*.sh       text eol=lf

# Binary assets (do not apply text/CRLF conversion)
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.avif binary
*.ico  binary
*.pdf  binary
